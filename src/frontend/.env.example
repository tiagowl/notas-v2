# =============================================================================
# Notas v2 — Variáveis de ambiente
# Copie para .env.local:  cp .env.example .env.local
# =============================================================================

# --- Frontend ---
NEXT_PUBLIC_APP_NAME=Notas v2

# URL da API (vazio = mesma origem do Next.js em /api/*)
NEXT_PUBLIC_API_URL=

# --- Banco de dados (Neon PostgreSQL) — obrigatório para o backend ---
# Connection pooler (uso em runtime)
DATABASE_URL=postgresql://USER:PASSWORD@ep-xxx-pooler.region.aws.neon.tech/notas?sslmode=require

# Conexão direta (migrations Prisma)
DIRECT_URL=postgresql://USER:PASSWORD@ep-xxx.region.aws.neon.tech/notas?sslmode=require

# =============================================================================
# Setup rápido
# =============================================================================
# 1. Configure DATABASE_URL e DIRECT_URL no Neon
# 2. npm install
# 3. npx prisma migrate dev --name init
#    (ou: npm run db:push)
# 4. npm run db:seed
#    (ou execute database/seed-test-data.sql no SQL Editor)
# 5. npm run dev
# =============================================================================
